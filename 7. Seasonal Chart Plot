

# Load libraries
library(forecast)
library(ggplot2)


# STEP 2: Create example monthly SST dataset

data <- data.frame(
  Year = rep(2020:2023, each = 12),
  Month = rep(1:12, times = 4),
  SST = c(
    25.1, 25.4, 26.0, 27.2, 28.4, 29.1, 29.5, 29.2, 28.6, 27.5, 26.3, 25.6,
    25.0, 25.3, 26.1, 27.3, 28.6, 29.3, 29.7, 29.4, 28.7, 27.6, 26.4, 25.7,
    25.2, 25.6, 26.3, 27.5, 28.7, 29.5, 29.9, 29.6, 28.9, 27.8, 26.6, 25.9,
    25.3, 25.7, 26.5, 27.7, 28.9, 29.7, 30.1, 29.8, 29.1, 28.0, 26.8, 26.0
  )
)

# Preview data
head(data)


# STEP 3: Convert SST data to time series object


sst_ts <- ts(
  data$SST,
  start = c(2020, 1),
  frequency = 12
)


# STEP 4: Seasonal Plot using Base R (forecast package)


seasonplot(
  sst_ts,
  col = rainbow(4),
  year.labels = TRUE,
  year.labels.left = TRUE,
  xlab = "Month",
  ylab = "Sea Surface Temperature (°C)",
  main = "Seasonal Plot of Monthly SST (2020–2023)"
)


# STEP 5: Seasonal Plot using ggplot2 (Jan–Dec enforced)


# Convert Month to ordered factor with all months
data$Month <- factor(
  month.abb[data$Month],
  levels = month.abb,
  ordered = TRUE
)

ggplot(data, aes(x = Month, y = SST, group = Year, color = factor(Year))) +
  geom_line(linewidth = 1) +
  geom_point(size = 2) +
  labs(
    title = "Seasonal Plot of Monthly SST (2020–2023)",
    x = "Month",
    y = "Sea Surface Temperature (°C)",
    color = "Year"
  ) +
  theme_minimal() +
  theme(
    plot.title = element_text(hjust = 0.5)
  )
