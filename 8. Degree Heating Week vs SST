
# Load Libraries

library(readxl)
library(ggplot2)
library(dplyr)

# Import Data

data <- read_excel("DHW DATA/DWH vs SST-correct.xlsx")

data$SST <- as.numeric(data$SST)
data$DHW <- as.numeric(data$DHW)

data <- na.omit(data)


# Linear Regression

model <- lm(DHW ~ SST, data = data)

r2 <- summary(model)$r.squared
p_value <- summary(model)$coefficients[2,4]

label_text <- paste0(
  "R² = ", round(r2,3),
  "\np = ", round(p_value,3)
)


# Plot

ggplot(data, aes(x = SST, y = DHW)) +
  
  geom_point(size = 3.5, color = "black") +
  
  geom_smooth(method = "lm",
              color = "#2C6BAA",
              fill = "#A6C8E0",
              se = TRUE,
              linewidth = 1.1) +
  
  annotate("text",
           x = min(data$SST) + 0.1,
           y = max(data$DHW) - 0.1,
           label = label_text,
           size = 4.5,
           hjust = 0,
           vjust = 1,
           fontface = "bold") +
  
  labs(
    title = "Relationship Between DHW and SST (2010)",
    x = "Sea Surface Temperature (SST)",
    y = "Degree Heating Weeks (DHW)"
  ) +
  
  theme_minimal(base_size = 14) +
  
  theme(
    plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
    axis.title = element_text(size = 15, face = "bold"),
    axis.text = element_text(size = 12),
    panel.border = element_rect(color = "black", fill = NA, linewidth = 1),
    panel.grid.major = element_line(color = "grey80"),
    panel.grid.minor = element_line(color = "grey90")
  )
